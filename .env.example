# graphify — 로컬 개발 (복사: cp .env.example .env.dev)
# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8081

# Backend (Spring — application-dev.yml 기본값과 동일)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/graphify
SPRING_DATASOURCE_USERNAME=graphify
SPRING_DATASOURCE_PASSWORD=graphify

# Backend secrets (API 키 AES 암호화 — application-dev.yml graphify.secrets.encryption-key 와 동일)
# GRAPHIFY_SECRETS_ENCRYPTION_KEY=dev-only-change-me-graphify-secrets-key-256bits-min!!

# 시장 뉴스 (선택) — https://newsapi.org 키. 없으면 한국 경제 RSS만 사용
NEWS_API_KEY=

# Open DART (기업 검색·상세 동기화) — https://opendart.fss.or.kr
DART_API_KEY=

# KRX Data Marketplace Open API (일별매매·공식 종가) — https://openapi.krx.co.kr
# 키 이름은 공백 없이 KRX_API_KEY=... 형식 권장 (API_KEY= 도 fallback 지원)
KRX_API_KEY=

# 시장 시세 (선택)
MARKET_PROVIDER=composite
MARKET_NAVER_ENABLED=true
MARKET_YAHOO_ENABLED=true

# Azure OpenAI / 호환 게이트웨이 (Agent 인사이트)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_API_VERSION=2024-12-01-preview
OPENAI_AUTH_MODE=api-key
# Azure 배포명 (게이트웨이에 실제 존재하는 이름, 예: gpt-4o)
OPENAI_DEPLOYMENT=gpt-4o
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_DEPLOYMENT=gpt-4o
OPENAI_MAX_TOKENS=4096

# pgAdmin (docker compose — ./init.sh start 시 함께 기동)
GRAPHIFY_PGADMIN_PORT=5050
GRAPHIFY_PGADMIN_EMAIL=admin@graphify.dev
GRAPHIFY_PGADMIN_PASSWORD=admin
