{
  "openapi": "3.0.3",
  "info": {
    "title": "NPO 장애 관리 API",
    "description": "Npo Agent Platform - 장애 관리 Agent용 MCP API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://<YOUR_CLOUD_RUN_URL>",
      "description": "Google Cloud Run (Production)"
    }
  ],
  "paths": {
    "/api/npo/incidents/all": {
      "get": {
        "summary": "전체 장애 이력 조회",
        "description": "조건 없이 모든 장애 데이터를 반환합니다.",
        "operationId": "getAllIncidents",
        "responses": {
          "200": {
            "description": "전체 장애 목록",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Incident" }
                }
              }
            }
          }
        }
      }
    },
    "/api/npo/incidents": {
      "get": {
        "summary": "장애 목록 조회",
        "description": "상태, 심각도, 날짜 범위 필터로 장애 목록을 조회합니다.",
        "operationId": "getIncidents",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "장애 상태 (OPEN, INVESTIGATING, RESOLVED, CLOSED)",
            "schema": { "type": "string", "enum": ["OPEN", "INVESTIGATING", "RESOLVED", "CLOSED"] }
          },
          {
            "name": "severity",
            "in": "query",
            "required": false,
            "description": "심각도 (CRITICAL, HIGH, MEDIUM, LOW)",
            "schema": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "description": "조회 시작일 (yyyy-MM-dd)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "조회 종료일 (yyyy-MM-dd)",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "장애 목록",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Incident" }
                }
              }
            }
          }
        }
      }
    },
    "/api/npo/incidents/history": {
      "get": {
        "summary": "장애 이력 조회",
        "description": "기간별, 서비스별로 해결/종료된 장애 이력을 조회합니다.",
        "operationId": "getIncidentHistory",
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "description": "조회 시작일 (yyyy-MM-dd)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "조회 종료일 (yyyy-MM-dd)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "service",
            "in": "query",
            "required": false,
            "description": "서비스명 (예: payment, auth, database)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "장애 이력 목록",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Incident" }
                }
              }
            }
          }
        }
      }
    },
    "/api/npo/incidents/stats": {
      "get": {
        "summary": "장애 통계 조회",
        "description": "기간 내 장애 건수, MTTR, 재발률 등 통계를 조회합니다.",
        "operationId": "getIncidentStats",
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "description": "조회 시작일 (yyyy-MM-dd)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "조회 종료일 (yyyy-MM-dd)",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "장애 통계",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IncidentStats" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Incident": {
        "type": "object",
        "properties": {
          "id":          { "type": "string", "example": "INC-001" },
          "title":       { "type": "string", "example": "결제 서비스 응답 지연" },
          "description": { "type": "string", "example": "결제 API 평균 응답시간 10초 초과" },
          "status":      { "type": "string", "enum": ["OPEN", "INVESTIGATING", "RESOLVED", "CLOSED"] },
          "severity":    { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
          "service":     { "type": "string", "example": "payment" },
          "occurredAt":  { "type": "string", "format": "date-time" },
          "resolvedAt":  { "type": "string", "format": "date-time", "nullable": true },
          "mttrMinutes": { "type": "integer", "nullable": true, "description": "장애 해결 소요 시간(분)" }
        }
      },
      "IncidentStats": {
        "type": "object",
        "properties": {
          "totalCount":     { "type": "integer", "description": "전체 장애 건수" },
          "criticalCount":  { "type": "integer", "description": "CRITICAL 건수" },
          "highCount":      { "type": "integer", "description": "HIGH 건수" },
          "mediumCount":    { "type": "integer", "description": "MEDIUM 건수" },
          "lowCount":       { "type": "integer", "description": "LOW 건수" },
          "mttrMinutes":    { "type": "number", "description": "평균 장애 해결 시간(분)" },
          "recurrenceRate": { "type": "number", "description": "재발률 (%)" }
        }
      }
    }
  }
}
