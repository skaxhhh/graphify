@baseUrl = http://localhost:8081
@adminToken = {{adminLogin.response.body.data.accessToken}}
@userToken = {{userLogin.response.body.data.accessToken}}

### 관리자 로그인
# @name adminLogin
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "admin@graphify.dev",
  "password": "admin1234"
}

###

### 일반 사용자 로그인
# @name userLogin
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "demo@graphify.dev",
  "password": "password123"
}

###

### GET /admin/agent/stats?period=day — 성공
GET {{baseUrl}}/api/v1/admin/agent/stats?period=day
Authorization: Bearer {{adminToken}}

###

### GET /admin/agent/stats?period=week — 성공
GET {{baseUrl}}/api/v1/admin/agent/stats?period=week
Authorization: Bearer {{adminToken}}

###

### GET /admin/agent/stats — 실패 (잘못된 period)
GET {{baseUrl}}/api/v1/admin/agent/stats?period=month
Authorization: Bearer {{adminToken}}

###

### GET /admin/users/usage — 성공
GET {{baseUrl}}/api/v1/admin/users/usage
Authorization: Bearer {{adminToken}}

###

### GET /admin/agent/stats — 실패 (일반 사용자 403)
GET {{baseUrl}}/api/v1/admin/agent/stats?period=day
Authorization: Bearer {{userToken}}

###

### GET /admin/agent/stats — 실패 (미인증)
GET {{baseUrl}}/api/v1/admin/agent/stats?period=day

###
