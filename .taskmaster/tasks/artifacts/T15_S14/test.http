@baseUrl = http://localhost:8081
@adminToken = {{adminLogin.response.body.data.accessToken}}
@userToken = {{userLogin.response.body.data.accessToken}}
@toolId = 1

### 관리자 로그인
# @name adminLogin
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "admin@graphify.dev",
  "password": "admin1234"
}

###

### GET /admin/tools — 성공
GET {{baseUrl}}/api/v1/admin/tools
Authorization: Bearer {{adminToken}}

###

### GET /admin/tools?q=company — 성공
GET {{baseUrl}}/api/v1/admin/tools?q=company&status=CONNECTED
Authorization: Bearer {{adminToken}}

###

### POST /admin/tools — 성공
POST {{baseUrl}}/api/v1/admin/tools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "test-tool",
  "description": "테스트 MCP",
  "endpointUrl": "http://localhost:8090/mcp/test",
  "authType": "NONE",
  "enabled": true,
  "allowedRoles": ["USER", "ADMIN"]
}

###

### PUT /admin/tools/{id} — 성공
PUT {{baseUrl}}/api/v1/admin/tools/{{toolId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "company-search",
  "description": "기업 검색 MCP (수정)",
  "endpointUrl": "http://localhost:8090/mcp/company-search",
  "authType": "API_KEY",
  "authSecret": "dev-key",
  "enabled": true,
  "allowedRoles": ["USER", "PREMIUM"]
}

###

### POST /admin/tools/{id}/ping — 성공
POST {{baseUrl}}/api/v1/admin/tools/{{toolId}}/ping
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{}

###

### DELETE /admin/tools/{id} — 성공 (test-tool id 사용 시)
# DELETE {{baseUrl}}/api/v1/admin/tools/4
# Authorization: Bearer {{adminToken}}

###

### GET /admin/tools — 실패 (일반 사용자 403)
GET {{baseUrl}}/api/v1/admin/tools
Authorization: Bearer {{userToken}}

###

### POST /admin/tools — 실패 (잘못된 authType)
POST {{baseUrl}}/api/v1/admin/tools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "bad-auth",
  "endpointUrl": "http://localhost:8090/mcp/bad",
  "authType": "INVALID",
  "allowedRoles": ["USER"]
}

###
